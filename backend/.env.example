# Portfolio Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# CORS - Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Contact info (optional - used by /contact endpoint)
CONTACT_EMAIL=koustav@example.com
CONTACT_LINKEDIN=https://linkedin.com/in/koustavmanna
CONTACT_TWITTER=https://twitter.com/koustavmanna
CONTACT_GITHUB=https://github.com/koustavmanna
